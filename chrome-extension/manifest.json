{
  "manifest_version": 3,
  "name": "TossPeek",
  "version": "0.1.0",
  "description": "계좌를 쳐다보지 말고, 느껴라. 툴바 구석에서 무드만 슬쩍 — 직장인용 스텔스 포트폴리오.",
  "permissions": ["alarms", "storage"],
  "host_permissions": [
    "http://127.0.0.1:17654/*",
    "http://localhost:17654/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TossPeek",
    "default_popup": "popup.html"
  },
  "commands": {
    "toggle-stealth": {
      "suggested_key": { "default": "Ctrl+Shift+9" },
      "description": "회색/숨김 토글 (보스키)"
    }
  }
}
